# FLIK Survey Intelligence — Environment Variables
# Copy to .env and fill in every value. NEVER commit .env to Git.

# SERVER
PORT=3000
NODE_ENV=production

# Session secret — run this to generate:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=REPLACE_WITH_64_CHAR_HEX

# APP USERS — JSON array of users who can log in
# Generate a password hash: npm run hash-password MyPassword123
# Then paste the hash below. One object per user.
# Format: [{"username":"hard","name":"Hard Parikh","passwordHash":"$2b$12$..."},...]
APP_USERS=[{"username":"hard","name":"Hard Parikh","passwordHash":"REPLACE_WITH_BCRYPT_HASH"},{"username":"analyst","name":"Analyst User","passwordHash":"REPLACE_WITH_BCRYPT_HASH"}]

# ANTHROPIC (Primary AI)
ANTHROPIC_API_KEY=sk-ant-REPLACE

# GROQ (Free fallback AI — get key at console.groq.com)
GROQ_API_KEY=gsk_REPLACE

# SNOWFLAKE
SNOWFLAKE_ACCOUNT=REPLACE
SNOWFLAKE_USERNAME=REPLACE
SNOWFLAKE_PASSWORD=REPLACE
SNOWFLAKE_DATABASE=FLIK_ANALYTICS
SNOWFLAKE_SCHEMA=CURIOSITY_WIDGETS
SNOWFLAKE_WAREHOUSE=REPLACE
SNOWFLAKE_ROLE=REPLACE

# MONGODB (Session storage — free at cloud.mongodb.com)
MONGODB_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/flik-sessions?retryWrites=true&w=majority
USE_MEMORY_SESSIONS=false

# RATE LIMITING
RATE_LIMIT_MAX_REQUESTS=30
